# Copy to apps/web/.env.local (merge with your existing NEXT_PUBLIC_API_URL, etc.)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Option A: full issuer (preferred if already known)
# NEXT_PUBLIC_WEB_KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/nihongo-bjt

# Option B: base + realm (same result in the app)
NEXT_PUBLIC_WEB_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_WEB_KEYCLOAK_REALM=nihongo-bjt
NEXT_PUBLIC_WEB_KEYCLOAK_CLIENT_ID=nihongo-web

# Server-side OIDC (Next Route Handlers — not exposed to the browser)
WEB_KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/nihongo-bjt
WEB_KEYCLOAK_CLIENT_ID=nihongo-web
WEB_KEYCLOAK_CLIENT_SECRET=nihongo-web-dev-secret
WEB_PUBLIC_URL=http://localhost:3000

# Keycloak Admin REST (server only) — required for learner /register. Dev: Keycloak container admin.
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
