# Merge into the environment used by apps/api (e.g. root .env).
# JWKS URL is optional — the API defaults to ${KEYCLOAK_ISSUER_URL}/protocol/openid-connect/certs

KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/nihongo-bjt
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/nihongo-bjt/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=nihongo-web
KEYCLOAK_EXPECTED_AUDIENCE=nihongo-web,nihongo-admin
