/// Versioned legal policy documents (terms, privacy, cookie) with effective dates.
/// LegalConsentService reads the latest active version per policyKey to determine required consent.
/// Stop condition: adding a new effective version with a past date is forbidden — use effectiveAt >= now().
model LegalPolicy {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Policy key: "terms_of_service" | "privacy_policy" | "cookie_policy" | "tokusho" (Japanese e-commerce law)
  policyKey   String    @map("policy_key") @db.VarChar(64)
  /// Semver-style version string: "v1", "v1.1", "v2"
  version     String    @db.VarChar(32)
  /// ISO-8601 effective date. Policy only counts as required on/after this timestamp.
  effectiveAt DateTime  @map("effective_at") @db.Timestamptz(6)
  /// Policy body in Markdown. May be null for "publish coming soon" placeholders.
  contentMd   String?   @map("content_md")
  /// draft | published | archived
  status      String    @default("draft") @db.VarChar(32)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([policyKey, version], map: "uq_legal_policy_key_version")
  @@index([policyKey, effectiveAt, status], map: "idx_legal_policy_key_effective")
  @@map("legal_policy")
  @@schema("legal")
}

