/// Persisted battle lobby/room chat. The global lobby uses `room_key = global`; match rooms may link
/// to `battle_session` later. User display is snapshotted for readable chat history while user identity
/// remains the canonical `user_id`.
model BattleChatMessage {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomKey         String         @default("global") @map("room_key") @db.VarChar(64)
  sessionId       String?        @map("session_id") @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  displayName     String?        @map("display_name") @db.VarChar(120)
  message         String         @db.VarChar(500)
  kind            String         @default("chat") @db.VarChar(24)
  moderationState String         @default("visible") @map("moderation_state") @db.VarChar(24)
  metadata        Json           @default("{}")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  session         BattleSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([roomKey, createdAt], map: "idx_battle_chat_room_created")
  @@index([userId, createdAt], map: "idx_battle_chat_user_created")
  @@index([moderationState, createdAt], map: "idx_battle_chat_moderation")
  @@map("battle_chat_message")
  @@schema("learning")
}

model BattleRound {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId         String        @map("session_id") @db.Uuid
  roundIndex        Int           @map("round_index")
  questionId        String        @map("question_id") @db.Uuid
