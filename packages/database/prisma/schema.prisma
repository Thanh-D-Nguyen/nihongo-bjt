/// Incoming billing webhook events with idempotency and replay-protection.
/// rawPayload must only be accessed by admin actors with billing.webhook.manage permission.
/// Stop condition: any webhook without signatureVerified = true or idempotencyKey uniqueness must be blocked.
model BillingWebhookEvent {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Billing provider key: "local" | "stripe" | etc.
  provider          String    @db.VarChar(32)
  /// Canonical event type (e.g. "local_checkout_completed", "stripe.invoice.paid").
  eventType         String    @map("event_type") @db.VarChar(120)
  /// Idempotency key: unique constraint prevents replay attacks. For Stripe: the `evt_*` id.
  idempotencyKey    String    @unique @map("idempotency_key") @db.VarChar(255)
  /// True if the provider signature was verified (or this is a local event with no signature requirement).
  /// For external providers (Stripe etc.), MUST be true before processing. TODO: implement Stripe sig verify.
  signatureVerified Boolean   @default(false) @map("signature_verified")
  /// pending | processing | processed | failed | dead_lettered
  status            String    @default("pending") @db.VarChar(32)
  /// Raw payload — access-gated to admin actors with billing.webhook.manage. Never expose to learners.
  rawPayload        Json      @map("raw_payload")
  /// Structured metadata for observability (no PII). rawPayload is the source of truth.
  meta              Json      @default("{}")
  retryCount        Int       @default(0) @map("retry_count")
  lastError         String?   @map("last_error")
  receivedAt        DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)
  processedAt       DateTime? @map("processed_at") @db.Timestamptz(6)

  @@index([provider, status, receivedAt], map: "idx_billing_webhook_provider_status")
  @@index([eventType, receivedAt], map: "idx_billing_webhook_event_type")
  @@map("billing_webhook_event")
  @@schema("monetization")
}

