  userId            String        @map("user_id") @db.Uuid
  opponentUserId    String?       @map("opponent_user_id") @db.Uuid
  roomCode          String        @unique @map("room_code") @db.VarChar(16)
  mode              String        @default("bot") @map("mode") @db.VarChar(32)
