  userResponseMs     Int?          @map("user_response_ms")
  botOptionKey       String?       @map("bot_option_key") @db.VarChar(8)
  botCorrect         Boolean?      @map("bot_correct")
  botResponseMs      Int?          @map("bot_response_ms")
  opponentOptionKey  String?       @map("opponent_option_key") @db.VarChar(8)
  opponentCorrect    Boolean?      @map("opponent_correct")
  opponentResponseMs Int?          @map("opponent_response_ms")
  decidedAt          DateTime?     @map("decided_at") @db.Timestamptz(6)
  session            BattleSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question           BjtQuestion   @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([sessionId, roundIndex], map: "uq_battle_round_session_index")
  @@index([sessionId], map: "idx_battle_round_session_id")
  @@map("battle_round")
  @@schema("learning")
}

/// Admin-managed Battle bot persona. Distinct from the code-defined `BATTLE_BOT_PROFILES`
/// runtime registry: this row stores the editorial config (name, persona, accuracy/delay tuning,
/// vocabulary level, lifecycle) so operators can introduce or tune bots without redeploys. Mutated
/// only via the admin `battle/bots` surface; every change is audited via `admin.audit_log`.
model BattleBot {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  botKey           String   @unique @default(dbgenerated("'bot_'::text || replace((gen_random_uuid())::text, '-'::text, ''::text)")) @map("bot_key") @db.VarChar(64)
  name             String   @db.VarChar(80)
  difficulty       String   @db.VarChar(16)
  persona          String?
  accuracyPct      Int      @map("accuracy_pct")
  minDelayMs       Int      @map("min_delay_ms")
  maxDelayMs       Int      @map("max_delay_ms")
  vocabularyLevel  String   @map("vocabulary_level") @db.VarChar(32)
  avatarFallback   String   @default("B") @map("avatar_fallback") @db.VarChar(12)
  styleToken       String   @default("focused") @map("style_token") @db.VarChar(16)
  riveSrc          String?  @map("rive_src")
  riveArtboard     String   @default("BattleBot") @map("rive_artboard") @db.VarChar(80)
  riveStateMachine String   @default("BattleBot") @map("rive_state_machine") @db.VarChar(80)
  riveLicense      String?  @map("rive_license") @db.VarChar(120)
  riveProvenance   Json     @default("{}") @map("rive_provenance")
  status           String   @default("active") @db.VarChar(16)
  createdById      String?  @map("created_by_id") @db.Uuid
  updatedById      String?  @map("updated_by_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status], map: "idx_battle_bot_status")
  @@index([botKey], map: "idx_battle_bot_key")
  @@index([difficulty], map: "idx_battle_bot_difficulty")
  @@index([updatedAt], map: "idx_battle_bot_updated_at")
  @@map("battle_bot")
  @@schema("learning")
}

/// Battle abuse / fairness moderation queue. Created by users (or system-detected signals once
/// wired) against another player; admins triage via `battle/abuse` admin surface. `subjectId` is the
/// reported player; `reporterId` is nullable (system-generated reports). Resolution requires
/// `battle.manage` (no dedicated `battle.moderate` permission yet — gap recorded in inventory).
model BattleAbuseReport {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reporterId      String?   @map("reporter_id") @db.Uuid
  subjectId       String    @map("subject_id") @db.Uuid
  matchId         String?   @map("match_id") @db.Uuid
  severity        String    @default("medium") @db.VarChar(16)
  kind            String    @db.VarChar(32)
  description     String
  evidence        Json      @default("{}") @map("evidence")
  status          String    @default("open") @db.VarChar(16)
  actionTaken     String?   @map("action_taken") @db.VarChar(32)
  resolutionNotes String?   @map("resolution_notes")
  resolvedById    String?   @map("resolved_by_id") @db.Uuid
  resolvedAt      DateTime? @map("resolved_at") @db.Timestamptz(6)
  escalatedAt     DateTime? @map("escalated_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, createdAt], map: "idx_battle_abuse_status")
  @@index([subjectId, createdAt], map: "idx_battle_abuse_subject")
  @@index([severity, status], map: "idx_battle_abuse_severity")
  @@index([reporterId], map: "idx_battle_abuse_reporter")
  @@map("battle_abuse_report")
  @@schema("learning")
}

/// Cached tokenization + dictionary lookup by normalized text hash.
