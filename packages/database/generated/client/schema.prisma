// ═══════════════════════════════════════════════════════════════════════════════
// ── Interactive Exercises ───────────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════════

/// Admin-managed exercise type configuration per placement surface.
/// `displayOrder` controls the order in the UI for each placement.
model ExerciseConfig {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// word_order | cloze | translation | meaning_match | listening
  exerciseType     String   @map("exercise_type") @db.VarChar(32)
  /// practice_tab | post_review | daily_hub
  placement        String   @db.VarChar(32)
  displayOrder     Int      @default(0) @map("display_order")
  enabled          Boolean  @default(true)
  /// JLPT level range filter (nullable = all levels)
  minLevel         String?  @map("min_level") @db.VarChar(8)
  maxLevel         String?  @map("max_level") @db.VarChar(8)
  timeLimitSec     Int?     @map("time_limit_sec")
  pointsPerCorrect Int      @default(10) @map("points_per_correct")
  createdBy        String?  @map("created_by") @db.Uuid
  updatedBy        String?  @map("updated_by") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([exerciseType, placement], map: "uq_exercise_config_type_placement")
  @@index([placement, displayOrder], map: "idx_exercise_config_placement_order")
  @@map("exercise_config")
  @@schema("exercise")
}

/// A generated exercise instance. Exercises are generated on-the-fly from
/// existing content (Lexeme, GrammarPoint, Kanji, ExampleSentence) and cached.
model Exercise {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// word_order | cloze | translation | meaning_match | listening
  exerciseType  String           @map("exercise_type") @db.VarChar(32)
  /// lexeme | grammar | kanji
  sourceType    String           @map("source_type") @db.VarChar(32)
  sourceId      String           @map("source_id") @db.Uuid
  /// N5 | N4 | N3 | N2 | N1
  level         String?          @db.VarChar(8)
  /// JSON: question text, audio URL, shuffled tokens, image URL, etc.
  prompt        Json
  /// JSON: options array for multiple-choice exercises
  choices       Json             @default("[]")
  /// JSON: correct answer data (ordered tokens, correct option key, etc.)
  correctAnswer Json             @map("correct_answer")
  /// Explanation shown after answering
  explanation   String?
  /// easy | medium | hard
  difficulty    String           @default("medium") @db.VarChar(16)
  tags          String[]         @default([])
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  answers       ExerciseAnswer[]

  @@index([exerciseType, level], map: "idx_exercise_type_level")
  @@index([sourceType, sourceId], map: "idx_exercise_source")
  @@map("exercise")
  @@schema("exercise")
}

/// Tracks a user's exercise practice session (a batch of exercises).
model ExerciseSession {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String           @map("user_id") @db.Uuid
  /// practice_tab | post_review | daily_hub
  sessionType        String           @map("session_type") @db.VarChar(32)
  /// word_order | cloze | translation | meaning_match | listening | mixed
  exerciseType       String           @map("exercise_type") @db.VarChar(32)
  level              String?          @db.VarChar(8)
  /// in_progress | completed | abandoned
  status             String           @default("in_progress") @db.VarChar(32)
  totalQuestions     Int              @default(0) @map("total_questions")
  correctCount       Int              @default(0) @map("correct_count")
  score              Int              @default(0)
  /// Whether this session was counted towards streak
  streakContribution Boolean          @default(false) @map("streak_contribution")
  startedAt          DateTime         @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt        DateTime?        @map("completed_at") @db.Timestamptz(6)
  answers            ExerciseAnswer[]

  @@index([userId, status], map: "idx_exercise_session_user_status")
  @@index([userId, startedAt], map: "idx_exercise_session_user_started")
  @@map("exercise_session")
  @@schema("exercise")
}

/// Individual exercise answer within a session.
model ExerciseAnswer {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId   String          @map("session_id") @db.Uuid
  exerciseId  String          @map("exercise_id") @db.Uuid
  /// JSON: the user's submitted answer
  userAnswer  Json            @map("user_answer")
  isCorrect   Boolean         @map("is_correct")
  timeSpentMs Int             @default(0) @map("time_spent_ms")
  answeredAt  DateTime        @default(now()) @map("answered_at") @db.Timestamptz(6)
  session     ExerciseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise    Exercise        @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([sessionId, answeredAt], map: "idx_exercise_answer_session")
  @@index([exerciseId], map: "idx_exercise_answer_exercise")
  @@map("exercise_answer")
  @@schema("exercise")
}

