generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["admin", "analytics", "assessment", "auth", "authz", "battle", "billing", "career", "content", "curriculum", "daily", "exercise", "gamification", "growth", "iam", "learning", "legal", "l10n", "media", "monetization", "ops", "profile"]
}

model ContentImportBatch {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceType        String                 @map("source_type") @db.VarChar(64)
  sourceDir         String                 @map("source_dir")
  status            String                 @default("created") @db.VarChar(32)
  fileCount         Int                    @default(0) @map("file_count")
  itemCount         Int                    @default(0) @map("item_count")
  errorCount        Int                    @default(0) @map("error_count")
  profileSummary    Json?                  @map("profile_summary")
  validationSummary Json?                  @map("validation_summary")
  transformSummary  Json?                  @map("transform_summary")
  startedAt         DateTime?              @map("started_at") @db.Timestamptz(6)
  completedAt       DateTime?              @map("completed_at") @db.Timestamptz(6)
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  rawItems          ContentRawItem[]
  errors            ContentImportError[]
  mappings          ContentImportMapping[]

  @@index([status, createdAt], map: "idx_content_import_batch_status_created_at")
  @@map("content_import_batch")
  @@schema("content")
}

model ContentRawItem {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  importBatchId   String               @map("import_batch_id") @db.Uuid
  sourceFile      String               @map("source_file")
  sourceType      String               @map("source_type") @db.VarChar(64)
  sourceKey       String               @map("source_key")
  itemIndex       Int                  @map("item_index")
  rawHash         String               @map("raw_hash") @db.Char(64)
  raw             Json
  profile         Json?
  validationState String               @default("pending") @map("validation_state") @db.VarChar(32)
  provenance      Json?
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  batch           ContentImportBatch   @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  errors          ContentImportError[]

  @@unique([importBatchId, sourceFile, sourceKey], map: "uq_content_raw_item_batch_file_key")
  @@unique([importBatchId, sourceFile, rawHash], map: "uq_content_raw_item_batch_file_hash")
  @@index([sourceType, sourceKey], map: "idx_content_raw_item_source")
  @@index([validationState], map: "idx_content_raw_item_validation_state")
  @@map("content_raw_item")
  @@schema("content")
}

model ContentImportError {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  importBatchId String             @map("import_batch_id") @db.Uuid
  rawItemId     String?            @map("raw_item_id") @db.Uuid
  sourceFile    String?            @map("source_file")
  sourceKey     String?            @map("source_key")
  phase         String             @db.VarChar(32)
  severity      String             @default("error") @db.VarChar(16)
  code          String             @db.VarChar(80)
  message       String
  sample        Json?
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  batch         ContentImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  rawItem       ContentRawItem?    @relation(fields: [rawItemId], references: [id], onDelete: SetNull)

  @@index([importBatchId, phase, severity], map: "idx_content_import_error_batch_phase")
  @@map("content_import_error")
  @@schema("content")
}

model ContentImportMapping {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  importBatchId String?             @map("import_batch_id") @db.Uuid
  sourceType    String              @map("source_type") @db.VarChar(64)
  targetType    String              @map("target_type") @db.VarChar(64)
  version       Int                 @default(1)
  status        String              @default("draft") @db.VarChar(32)
  mapping       Json
  notes         String?
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  batch         ContentImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@unique([sourceType, targetType, version], map: "uq_content_import_mapping_type_target_version")
  @@index([status, sourceType], map: "idx_content_import_mapping_status_source")
  @@map("content_import_mapping")
  @@schema("content")
}

model Lexeme {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  headword       String
  reading        String?
  kanjiMeaningVi String?       @map("kanji_meaning_vi")
  jlptLevel      String?       @map("jlpt_level")
  shortMeaningVi String?       @map("short_meaning_vi")
  /// Pitch accent + mora tokenization from javi `pronunciation` (may be missing per entry).
  pronunciation  Json?         @map("pronunciation")
  status         String        @default("active") @db.VarChar(32)
  reviewReasons  Json?         @map("review_reasons")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  senses         LexemeSense[]

  @@index([headword], map: "idx_lexeme_headword")
  @@index([status], map: "idx_lexeme_status")
  @@map("lexeme")
  @@schema("content")
}

model LexemeReverseProjection {
  id                 String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vietnameseHeadword String                   @map("vietnamese_headword")
  status             String                   @default("active") @db.VarChar(32)
  reviewReasons      Json?                    @map("review_reasons")
  createdAt          DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  candidates         LexemeReverseCandidate[]

  @@index([vietnameseHeadword], map: "idx_lexeme_reverse_projection_headword")
  @@index([status], map: "idx_lexeme_reverse_projection_status")
  @@map("lexeme_reverse_projection")
  @@schema("content")
}

model Kanji {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  character       String           @db.VarChar(8)
  meaningVi       String?          @map("meaning_vi")
  onyomi          String?
  kunyomi         String?
  strokeCount     Int?             @map("stroke_count")
  level           Int?
  frequency       Int?
  detail          String?
  tip             String?
  imagePath       String?          @map("image_path")
  strokeSvgPath   String?          @map("stroke_svg_path")
  strokeSvgHash   String?          @map("stroke_svg_hash") @db.Char(64)
  strokeSvgSource String?          @map("stroke_svg_source")
  status          String           @default("active") @db.VarChar(32)
  reviewReasons   Json?            @map("review_reasons")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  examples        KanjiExample[]
  components      KanjiComponent[]

  @@unique([character], map: "uq_kanji_character")
  @@index([character], map: "idx_kanji_character")
  @@index([status], map: "idx_kanji_status")
  @@map("kanji")
  @@schema("content")
}

model GrammarPoint {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pattern       String
  meaningVi     String               @map("meaning_vi")
  jlptLevel     String?              @map("jlpt_level")
  category      String?
  status        String               @default("active") @db.VarChar(32)
  reviewReasons Json?                @map("review_reasons")
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  details       GrammarPointDetail[]

  @@index([pattern], map: "idx_grammar_point_pattern")
  @@index([jlptLevel], map: "idx_grammar_point_jlpt_level")
  @@index([status], map: "idx_grammar_point_status")
  @@map("grammar_point")
  @@schema("content")
}

model ExampleSentence {
  id                       String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  japaneseText             String                          @map("japanese_text")
  reading                  String?
  translationVi            String?                         @map("translation_vi")
  sourceLanguageConfidence Float?                          @map("source_language_confidence")
  status                   String                          @default("active") @db.VarChar(32)
  reviewReasons            Json?                           @map("review_reasons")
  createdAt                DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                        @updatedAt @map("updated_at") @db.Timestamptz(6)
  lexemeSenseExamples      LexemeSenseExample[]
  reverseCandidateExamples LexemeReverseCandidateExample[]
  grammarDetailExamples    GrammarPointDetailExample[]

  @@index([japaneseText], map: "idx_example_sentence_japanese_text")
  @@index([status], map: "idx_example_sentence_status")
  @@map("example_sentence")
  @@schema("content")
}

model EntityImportProvenance {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType    String   @map("entity_type") @db.VarChar(80)
  entityId      String   @map("entity_id") @db.Uuid
  sourceType    String   @map("source_type") @db.VarChar(64)
  sourceKey     String   @map("source_key")
  sourceFile    String   @map("source_file")
  importBatchId String   @map("import_batch_id") @db.Uuid
  rawHash       String   @map("raw_hash") @db.Char(64)
  rawItemId     String   @map("raw_item_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([entityType, entityId], map: "uq_entity_import_provenance_entity")
  @@unique([sourceType, sourceKey], map: "uq_entity_import_provenance_source")
  @@index([importBatchId], map: "idx_entity_import_provenance_batch")
  @@map("entity_import_provenance")
  @@schema("content")
}

model LexemeSense {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lexemeId     String               @map("lexeme_id") @db.Uuid
  position     Int
  partOfSpeech String?              @map("part_of_speech")
  meaningVi    String               @map("meaning_vi")
  field        String?
  metadata     Json?
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  lexeme       Lexeme               @relation(fields: [lexemeId], references: [id], onDelete: Cascade)
  exampleLinks LexemeSenseExample[]

  @@unique([lexemeId, position], map: "uq_lexeme_sense_position")
  @@index([partOfSpeech], map: "idx_lexeme_sense_part_of_speech")
  @@map("lexeme_sense")
  @@schema("content")
}

model LexemeSenseExample {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  senseId           String           @map("sense_id") @db.Uuid
  exampleSentenceId String?          @map("example_sentence_id") @db.Uuid
  sourceExampleKey  String           @map("source_example_key")
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  sense             LexemeSense      @relation(fields: [senseId], references: [id], onDelete: Cascade)
  exampleSentence   ExampleSentence? @relation(fields: [exampleSentenceId], references: [id], onDelete: SetNull)

  @@unique([senseId, sourceExampleKey], map: "uq_lexeme_sense_example_source")
  @@index([exampleSentenceId], map: "idx_lexeme_sense_example_sentence")
  @@map("lexeme_sense_example")
  @@schema("content")
}

model LexemeReverseCandidate {
  id           String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectionId String                          @map("projection_id") @db.Uuid
  position     Int
  partOfSpeech String?                         @map("part_of_speech")
  japaneseText String                          @map("japanese_text")
  reading      String?
  kanjiText    String?                         @map("kanji_text")
  metadata     Json?
  createdAt    DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)
  projection   LexemeReverseProjection         @relation(fields: [projectionId], references: [id], onDelete: Cascade)
  exampleLinks LexemeReverseCandidateExample[]

  @@unique([projectionId, position], map: "uq_lexeme_reverse_candidate_position")
  @@index([japaneseText], map: "idx_lexeme_reverse_candidate_japanese_text")
  @@map("lexeme_reverse_candidate")
  @@schema("content")
}

model LexemeReverseCandidateExample {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  candidateId       String                 @map("candidate_id") @db.Uuid
  exampleSentenceId String?                @map("example_sentence_id") @db.Uuid
  sourceExampleKey  String                 @map("source_example_key")
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  candidate         LexemeReverseCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  exampleSentence   ExampleSentence?       @relation(fields: [exampleSentenceId], references: [id], onDelete: SetNull)

  @@unique([candidateId, sourceExampleKey], map: "uq_lexeme_reverse_candidate_example_source")
  @@index([exampleSentenceId], map: "idx_lexeme_reverse_candidate_example_sentence")
  @@map("lexeme_reverse_candidate_example")
  @@schema("content")
}

model GrammarPointDetail {
  id             String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  grammarPointId String                      @map("grammar_point_id") @db.Uuid
  position       Int
  meaningVi      String?                     @map("meaning_vi")
  explanation    String?
  note           String?
  synopsis       String?
  metadata       Json?
  createdAt      DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  grammarPoint   GrammarPoint                @relation(fields: [grammarPointId], references: [id], onDelete: Cascade)
  exampleLinks   GrammarPointDetailExample[]

  @@unique([grammarPointId, position], map: "uq_grammar_point_detail_position")
  @@map("grammar_point_detail")
  @@schema("content")
}

model GrammarPointDetailExample {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  detailId          String             @map("detail_id") @db.Uuid
  exampleSentenceId String?            @map("example_sentence_id") @db.Uuid
  sourceExampleKey  String             @map("source_example_key")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  detail            GrammarPointDetail @relation(fields: [detailId], references: [id], onDelete: Cascade)
  exampleSentence   ExampleSentence?   @relation(fields: [exampleSentenceId], references: [id], onDelete: SetNull)

  @@unique([detailId, sourceExampleKey], map: "uq_grammar_point_detail_example_source")
  @@index([exampleSentenceId], map: "idx_grammar_point_detail_example_sentence")
  @@map("grammar_point_detail_example")
  @@schema("content")
}

model KanjiExample {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kanjiId   String   @map("kanji_id") @db.Uuid
  position  Int
  hanViet   String?  @map("han_viet")
  meaningVi String?  @map("meaning_vi")
  reading   String?
  word      String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  kanji     Kanji    @relation(fields: [kanjiId], references: [id], onDelete: Cascade)

  @@unique([kanjiId, position], map: "uq_kanji_example_position")
  @@index([word], map: "idx_kanji_example_word")
  @@map("kanji_example")
  @@schema("content")
}

model KanjiComponent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kanjiId   String   @map("kanji_id") @db.Uuid
  position  Int
  hanViet   String?  @map("han_viet")
  character String   @db.VarChar(8)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  kanji     Kanji    @relation(fields: [kanjiId], references: [id], onDelete: Cascade)

  @@unique([kanjiId, position], map: "uq_kanji_component_position")
  @@index([character], map: "idx_kanji_component_character")
  @@map("kanji_component")
  @@schema("content")
}

model MediaAsset {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId    String?         @map("owner_user_id") @db.Uuid
  objectKey      String          @map("object_key")
  mimeType       String          @map("mime_type") @db.VarChar(120)
  byteSize       Int?            @map("byte_size")
  checksumSha256 String?         @map("checksum_sha256") @db.Char(64)
  provider       String          @default("local") @db.VarChar(64)
  sourceUrl      String?         @map("source_url")
  license        String?
  provenance     Json?
  accessibility  Json?
  rightsStatus   String          @default("pending_review") @map("rights_status") @db.VarChar(32)
  status         String          @default("active") @db.VarChar(32)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  cardLinks      CardMediaLink[]
  profileAvatars UserProfile[]

  @@unique([objectKey], map: "uq_media_asset_object_key")
  @@index([ownerUserId, createdAt], map: "idx_media_asset_owner_created_at")
  @@index([rightsStatus], map: "idx_media_asset_rights_status")
  @@map("asset")
  @@schema("media")
}

model Deck {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId   String?    @map("owner_user_id") @db.Uuid
  titleVi       String     @map("title_vi")
  titleJa       String?    @map("title_ja")
  descriptionVi String?    @map("description_vi")
  descriptionJa String?    @map("description_ja")
  visibility    String     @default("private") @db.VarChar(32)
  status        String     @default("active") @db.VarChar(32)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  cards         DeckCard[]

  @@index([ownerUserId, createdAt], map: "idx_deck_owner_created_at")
  @@index([visibility, status], map: "idx_deck_visibility_status")
  @@map("deck")
  @@schema("learning")
}

model FlashcardVariant {
  id                   String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceType           String          @map("source_type") @db.VarChar(64)
  sourceId             String          @map("source_id") @db.Uuid
  frontText            String          @map("front_text")
  backText             String          @map("back_text")
  reading              String?
  status               String          @default("active") @db.VarChar(32)
  createdAt            DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deckLinks            DeckCard[]
  mediaLinks           CardMediaLink[]
  remediationQuestions BjtQuestion[]   @relation("BjtQuestionRemediationCard")
  userFlashcards       UserFlashcard[]

  @@index([sourceType, sourceId], map: "idx_flashcard_variant_source")
  @@index([status], map: "idx_flashcard_variant_status")
  @@map("flashcard_variant")
  @@schema("learning")
}

model DeckCard {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deckId    String           @map("deck_id") @db.Uuid
  cardId    String           @map("card_id") @db.Uuid
  position  Int
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  deck      Deck             @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card      FlashcardVariant @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([deckId, cardId], map: "uq_deck_card_card")
  @@unique([deckId, position], map: "uq_deck_card_position")
  @@map("deck_card")
  @@schema("learning")
}

model UserFlashcard {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  cardId       String           @map("card_id") @db.Uuid
  state        String           @default("new") @db.VarChar(32)
  dueAt        DateTime         @default(now()) @map("due_at") @db.Timestamptz(6)
  intervalDays Int              @default(0) @map("interval_days")
  easeFactor   Float            @default(2.5) @map("ease_factor")
  repetitions  Int              @default(0)
  lapses       Int              @default(0)
  leeched      Boolean          @default(false)
  comebackMode Boolean          @default(false) @map("comeback_mode")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  card         FlashcardVariant @relation(fields: [cardId], references: [id], onDelete: Cascade)
  reviews      ReviewEvent[]

  @@unique([userId, cardId], map: "uq_user_flashcard_card")
  @@index([userId, dueAt], map: "idx_user_flashcard_due")
  @@map("user_flashcard")
  @@schema("learning")
}

model ReviewEvent {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  userFlashcardId String        @map("user_flashcard_id") @db.Uuid
  rating          String        @db.VarChar(16)
  elapsedMs       Int?          @map("elapsed_ms")
  previousDueAt   DateTime      @map("previous_due_at") @db.Timestamptz(6)
  nextDueAt       DateTime      @map("next_due_at") @db.Timestamptz(6)
  reviewedAt      DateTime      @default(now()) @map("reviewed_at") @db.Timestamptz(6)
  userFlashcard   UserFlashcard @relation(fields: [userFlashcardId], references: [id], onDelete: Cascade)

  @@index([userId, reviewedAt], map: "idx_review_event_user_reviewed_at")
  @@index([userFlashcardId, reviewedAt], map: "idx_review_event_card_reviewed_at")
  @@map("review_event")
  @@schema("learning")
}

model CardMediaLink {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cardId    String           @map("card_id") @db.Uuid
  assetId   String           @map("asset_id") @db.Uuid
  role      String           @default("primary_image") @db.VarChar(32)
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  card      FlashcardVariant @relation(fields: [cardId], references: [id], onDelete: Cascade)
  asset     MediaAsset       @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@unique([cardId, assetId, role], map: "uq_card_media_link_role")
  @@index([assetId], map: "idx_card_media_link_asset")
  @@map("card_media_link")
  @@schema("learning")
}

model Bookmark {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  targetType String   @map("target_type") @db.VarChar(32)
  targetId   String   @map("target_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, targetType, targetId], map: "uq_bookmark_user_target")
  @@index([userId, targetType, createdAt], map: "idx_bookmark_user_type_created")
  @@map("bookmark")
  @@schema("learning")
}

/// Managed battle mode/arena configuration: name, level, question pool, scoring rules, lifecycle.
/// Distinct from `BattleSession` (live runtime sessions) and from the code-defined `BATTLE_BOT_PROFILES`
/// (bot personality matrix). Created/published/archived/duplicated via the admin Battle Configs surface.
model BattleConfig {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String    @db.VarChar(120)
  description        String?
  level              String    @db.VarChar(32)
  questionPoolKey    String    @map("question_pool_key") @db.VarChar(64)
  questionCount      Int       @map("question_count")
  timePerQuestionSec Int       @map("time_per_question_sec")
