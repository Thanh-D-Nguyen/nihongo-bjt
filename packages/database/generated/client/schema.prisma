  streakConfig     StreakConfig @relation(fields: [streakConfigId], references: [id], onDelete: Cascade)
  user             UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, streakConfigId], map: "uq_user_streak_user_config")
  @@index([userId, currentStreak], map: "idx_user_streak_user_current")
  @@map("user_streak")
  @@schema("gamification")
}

/// Admin-managed achievement definition (e.g. "Vocabulary Master", "Streak Champion").
model AchievementDefinition {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug           String            @unique @db.VarChar(128)
  /// i18n key for achievement name
  nameKey        String            @map("name_key") @db.VarChar(255)
  /// i18n key for achievement description
  descriptionKey String            @map("description_key") @db.VarChar(255)
  /// learning | social | streak | mastery | battle
  category       String            @db.VarChar(32)
  /// Metric to track: words_learned | exercises_completed | streak_days | battles_won | reviews_done | quizzes_passed | ...
  metricKey      String            @map("metric_key") @db.VarChar(64)
  iconUrl        String?           @map("icon_url")
  displayOrder   Int               @default(0) @map("display_order")
  enabled        Boolean           @default(true)
  createdBy      String?           @map("created_by") @db.Uuid
  updatedBy      String?           @map("updated_by") @db.Uuid
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  tiers          AchievementTier[]

  @@index([category, displayOrder], map: "idx_achievement_def_category_order")
  @@map("achievement_definition")
  @@schema("gamification")
}

/// Tiered threshold for an achievement (bronze → silver → gold → platinum).
model AchievementTier {
  id               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  achievementId    String                @map("achievement_id") @db.Uuid
  /// bronze | silver | gold | platinum
  tier             String                @db.VarChar(16)
  /// Numeric threshold to earn this tier (e.g. 10 for bronze, 50 for silver)
  threshold        Int
  /// Optional: quota_credit | badge_icon | title_prefix
  rewardType       String?               @map("reward_type") @db.VarChar(32)
  rewardValue      String?               @map("reward_value") @db.VarChar(255)
  iconUrl          String?               @map("icon_url")
  /// i18n key for tier-specific name (e.g. "achievement.vocab_master.gold")
  nameKey          String?               @map("name_key") @db.VarChar(255)
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  achievement      AchievementDefinition @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  userAchievements UserAchievement[]

  @@unique([achievementId, tier], map: "uq_achievement_tier_achievement_tier")
  @@index([achievementId, threshold], map: "idx_achievement_tier_threshold")
  @@map("achievement_tier")
  @@schema("gamification")
}

/// Tracks a user's progress toward and earning of an achievement tier.
model UserAchievement {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  achievementId   String          @map("achievement_id") @db.Uuid
  tierId          String          @map("tier_id") @db.Uuid
  currentProgress Int             @default(0) @map("current_progress")
  earnedAt        DateTime?       @map("earned_at") @db.Timestamptz(6)
  notifiedAt      DateTime?       @map("notified_at") @db.Timestamptz(6)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  tier            AchievementTier @relation(fields: [tierId], references: [id], onDelete: Cascade)
  user            UserProfile     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tierId], map: "uq_user_achievement_user_tier")
  @@index([userId, achievementId], map: "idx_user_achievement_user_achievement")
  @@index([userId, earnedAt], map: "idx_user_achievement_user_earned")
  @@map("user_achievement")
  @@schema("gamification")
}

/// Admin-managed leaderboard configurations (e.g. weekly XP, monthly battles won).
model LeaderboardConfig {
  id         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String             @db.VarChar(128)
  /// i18n key for display
  nameKey    String?            @map("name_key") @db.VarChar(255)
  /// points | streak | battles_won | exercises_completed | reviews_done
  metricType String             @map("metric_type") @db.VarChar(32)
  /// daily | weekly | monthly | all_time
  period     String             @db.VarChar(16)
  maxEntries Int                @default(100) @map("max_entries")
  enabled    Boolean            @default(true)
  createdBy  String?            @map("created_by") @db.Uuid
  updatedBy  String?            @map("updated_by") @db.Uuid
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  entries    LeaderboardEntry[]

  @@map("leaderboard_config")
  @@schema("gamification")
}

/// Cached / materialized leaderboard entries, recomputed periodically by BullMQ job.
model LeaderboardEntry {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leaderboardId String            @map("leaderboard_id") @db.Uuid
  userId        String            @map("user_id") @db.Uuid
  rank          Int
  score         Int
  periodStart   DateTime          @map("period_start") @db.Date
  periodEnd     DateTime          @map("period_end") @db.Date
  computedAt    DateTime          @default(now()) @map("computed_at") @db.Timestamptz(6)
  leaderboard   LeaderboardConfig @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)

  @@unique([leaderboardId, userId, periodStart], map: "uq_leaderboard_entry_board_user_period")
  @@index([leaderboardId, periodStart, rank], map: "idx_leaderboard_entry_board_period_rank")
  @@map("leaderboard_entry")
  @@schema("gamification")
}

// ═══════════════════════════════════════════════════════════════════════════════
// ── Auto Flashcard Generation ───────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════════

/// Admin-managed rule defining how flashcards are auto-generated from content.
model FlashcardGenRule {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String            @db.VarChar(128)
  /// lexeme | grammar | kanji
  sourceType      String            @map("source_type") @db.VarChar(32)
  /// JLPT level filter (null = all levels)
  filterLevel     String?           @map("filter_level") @db.VarChar(8)
  /// JSON: tag-based filters
  filterTags      Json              @default("[]") @map("filter_tags")
  /// jp_to_vn | vn_to_jp | both
  direction       String            @default("both") @db.VarChar(16)
  /// JSON: front/back template (field mapping, include reading, examples, etc.)
  cardTemplate    Json              @default("{}") @map("card_template")
  includeExamples Boolean           @default(true) @map("include_examples")
  includeAudio    Boolean           @default(false) @map("include_audio")
  enabled         Boolean           @default(true)
  priority        Int               @default(0)
  createdBy       String?           @map("created_by") @db.Uuid
  updatedBy       String?           @map("updated_by") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  jobs            FlashcardGenJob[]

  @@index([sourceType, enabled], map: "idx_flashcard_gen_rule_source_enabled")
  @@map("flashcard_gen_rule")
  @@schema("learning")
}

/// Tracks a flashcard generation job (manual trigger or daily cron).
model FlashcardGenJob {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ruleId         String?           @map("rule_id") @db.Uuid
  userId         String?           @map("user_id") @db.Uuid
  /// by_level | by_topic | by_weak_area | daily_auto
  mode           String            @db.VarChar(32)
  /// pending | running | completed | failed
  status         String            @default("pending") @db.VarChar(32)
  cardsGenerated Int               @default(0) @map("cards_generated")
  /// Output deck ID
  deckId         String?           @map("deck_id") @db.Uuid
  /// JSON: generation parameters (level, tags, direction, count, etc.)
  params         Json              @default("{}")
  errorMessage   String?           @map("error_message")
  startedAt      DateTime?         @map("started_at") @db.Timestamptz(6)
  completedAt    DateTime?         @map("completed_at") @db.Timestamptz(6)
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  rule           FlashcardGenRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt], map: "idx_flashcard_gen_job_user_created")
  @@index([status, createdAt], map: "idx_flashcard_gen_job_status_created")
  @@map("flashcard_gen_job")
  @@schema("learning")
}

/**
 * ── BJT Lessons ───────────────────────────────────────────
 */

model BjtLesson {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  levelCode     String   @map("level_code") @db.VarChar(4)
  sortOrder     Int      @map("sort_order")
  slug          String   @unique @db.VarChar(80)
  titleVi       String   @map("title_vi") @db.VarChar(200)
  titleJa       String   @map("title_ja") @db.VarChar(200)
  descriptionVi String?  @map("description_vi")
  descriptionJa String?  @map("description_ja")
  status        String   @default("active") @db.VarChar(32)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  items BjtLessonItem[]

  @@unique([levelCode, sortOrder], map: "uq_bjt_lesson_level_order")
  @@index([levelCode, status], map: "idx_bjt_lesson_level_status")
  @@map("bjt_lesson")
  @@schema("curriculum")
}

model BjtLessonItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId    String   @map("lesson_id") @db.Uuid
  contentType String   @map("content_type") @db.VarChar(20)
  contentId   String   @map("content_id") @db.Uuid
  sortOrder   Int      @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  lesson BjtLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, contentType, contentId], map: "uq_bjt_lesson_item_unique")
  @@index([lessonId, sortOrder], map: "idx_bjt_lesson_item_order")
  @@index([contentType, contentId], map: "idx_bjt_lesson_item_content")
  @@map("bjt_lesson_item")
  @@schema("curriculum")
}

// ═══════════════════════════════════════════════════════════════
// NHK News — persistent article storage, reading progress, bookmarks
// ═══════════════════════════════════════════════════════════════

model NhkArticle {
  id            String   @id @db.VarChar(64)
  sourceType    String   @map("source_type") @db.VarChar(16) // "easy" | "normal"
  title         String
  titleWithRuby String?  @map("title_with_ruby")
  url           String
  imageUrl      String?  @map("image_url")
  audioUrl      String?  @map("audio_url")
  difficulty    String?  @db.VarChar(32)
  bodyHtml      String?  @map("body_html")
  bodyPlain     String?  @map("body_plain")
  vocabulary    Json     @default("[]")
  publishedAt   DateTime @map("published_at") @db.Timestamptz(6)
  fetchedAt     DateTime @default(now()) @map("fetched_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  readingProgress NhkReadingProgress[]
  bookmarks       NhkBookmark[]

  @@index([sourceType, publishedAt(sort: Desc)], map: "idx_nhk_article_source_published")
  @@map("nhk_article")
  @@schema("content")
}

model NhkReadingProgress {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.VarChar(128)
  articleId   String   @map("article_id") @db.VarChar(64)
  readAt      DateTime @default(now()) @map("read_at") @db.Timestamptz(6)
  readTimeSec Int?     @map("read_time_sec")
  completed   Boolean  @default(false)

  article NhkArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId], map: "uq_nhk_reading_progress_user_article")
  @@index([userId, readAt(sort: Desc)], map: "idx_nhk_reading_progress_user")
  @@map("nhk_reading_progress")
  @@schema("learning")
}

model NhkBookmark {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.VarChar(128)
  articleId String   @map("article_id") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  article NhkArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId], map: "uq_nhk_bookmark_user_article")
  @@index([userId, createdAt(sort: Desc)], map: "idx_nhk_bookmark_user")
  @@map("nhk_bookmark")
  @@schema("learning")
}
