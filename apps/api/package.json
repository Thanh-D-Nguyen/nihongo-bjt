{
  "name": "@nihongo-bjt/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --exclude '**/node_modules/**' --exclude '**/.git/**' --exclude '**/.next/**' --exclude '**/.turbo/**' --exclude '**/dist/**' --exclude '**/coverage/**' src/main.ts",
    "dev:plain": "tsx src/main.ts",
