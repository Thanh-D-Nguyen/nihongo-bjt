# ────────────────────────────────────────────────
# NihonGo BJT — Web App (.env)
# Copy this file as .env and fill in your values.
# ────────────────────────────────────────────────

# ─── Public URL ──────────────────────────────────
WEB_PUBLIC_URL=http://localhost:3000

# ─── API ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
# Optional: server-side URL for Next route handlers (e.g. `/api/auth/me`). Also `WEB_API_URL` / `INTERNAL_API_URL`.
# Repo root `.env` is merged in `next.config.mjs`; use `API_URL=http://api:4000` in Docker when the browser still uses localhost.
# API_URL=http://api:4000

# ─── Keycloak OIDC (Server-side) ────────────────
# Issuer URL for the Keycloak realm (server-side only)
# These are also read by the Nest API in local dev: it merges this file (and .env.local) after root `.env`
# so you do not have to duplicate WEB_KEYCLOAK_* into the repo root for JWT verification.
WEB_KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/nihongo-bjt
# Or use these aliases:
# KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/nihongo-bjt

# Client ID registered in Keycloak for this web app
WEB_KEYCLOAK_CLIENT_ID=nihongo-web
# Or: KEYCLOAK_CLIENT_ID=nihongo-web

# Client secret (confidential client)
WEB_KEYCLOAK_CLIENT_SECRET=your-client-secret-here
# Or: KEYCLOAK_CLIENT_SECRET=your-client-secret-here

# ─── Keycloak Public (Client-side) ──────────────
# Used by client-side auth provider for token refresh
NEXT_PUBLIC_WEB_KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/nihongo-bjt
NEXT_PUBLIC_WEB_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_WEB_KEYCLOAK_REALM=nihongo-bjt

# ─── Keycloak Admin (for registration & password reset) ──
# Master realm admin credentials — used for self-service registration
# and forgot-password flows via Keycloak Admin REST API.
# In production, use a least-privilege service account instead.
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ─── Social Login (IdP Hints) ───────────────────
# Set the Keycloak IdP alias for each social provider.
# Leave empty or remove to hide the button.
# These must match the Identity Provider aliases in your Keycloak realm.
NEXT_PUBLIC_AUTH_GOOGLE_IDP_HINT=google
NEXT_PUBLIC_AUTH_FACEBOOK_IDP_HINT=facebook
NEXT_PUBLIC_AUTH_APPLE_IDP_HINT=apple
NEXT_PUBLIC_AUTH_LINE_IDP_HINT=line

# ─── Feature Flags ──────────────────────────────
# Set to "false" to hide the registration button/page
NEXT_PUBLIC_AUTH_REGISTRATION_ENABLED=true
