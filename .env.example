# The Nest API (`apps/api`) loads repo root `.env` first, then in non-production merges
# `apps/web/.env` and `apps/web/.env.local` without overriding existing keys — so local learner
# Keycloak vars can live only in the web env files.

NODE_ENV="development"

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:15432/nihongo_bjt?schema=content"
API_PORT="4000"
API_PUBLIC_URL="http://localhost:4000"
WEB_PUBLIC_URL="http://localhost:3000"
ADMIN_PUBLIC_URL="http://localhost:3001"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:4000"
# Optional: URL the **Next.js server** uses to call Nest (route handlers like `/api/auth/me`). In Docker use the service name, e.g. `http://api:4000`. Repo `apps/web/next.config.mjs` merges this file so you need not duplicate under `apps/web/`.
# API_URL="http://localhost:4000"
NEXT_PUBLIC_LOCAL_ADMIN_ACTOR_ID="00000000-0000-4000-8000-000000000001"
# Local/test-only authenticated admin browser QA bypass.
# Requires NODE_ENV!="production", localhost/127.0.0.1 API requests, and a seeded authz.admin_actor matching NEXT_PUBLIC_LOCAL_ADMIN_ACTOR_ID.
# Set both API/Admin app env vars together, then restart both dev servers:
# ADMIN_TEST_BYPASS="1"
# NEXT_PUBLIC_ADMIN_TEST_BYPASS="1"

REDIS_URL="redis://localhost:6379"
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY="local_dev_meili_master_key"

MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="nihongo-bjt-media"
MINIO_USE_SSL="false"
# Optional: comma-separated hostnames for server-side fetch when kanji stroke_svg_path is https (e.g. S3). MINIO_ENDPOINT, localhost, 127.0.0.1 are always allowed.
# KANJI_STROKE_SVG_FETCH_HOSTS="s3.ap-northeast-1.amazonaws.com"
# When stroke_svg_path is repo-relative (data/generated/kanji-strokes/<id>-<hex>.svg), the API resolves files under that folder. Set one of these if the process cwd is not the monorepo root (e.g. Docker): absolute path to repo root containing `data/generated/kanji-strokes/`.
# KANJI_STROKE_REPO_ROOT=""
# NIHONGO_BJT_REPO_ROOT=""

# Google OAuth (Phase 12). Required for /api/auth/google/* routes to work.
OAUTH_STATE_SECRET=""
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:4000/api/auth/google/callback"

# Keycloak OIDC (sole auth when issuer is set). Prefer separate learner/admin clients.
# Issuer is the realm URL, e.g. http://localhost:8080/realms/nihongo-bjt
# Local Docker Keycloak (docker/keycloak) uses HTTP only — use http:// in all KEYCLOAK_* / NEXT_PUBLIC_* URLs.
# Do not use https://localhost:8080 unless you terminate TLS in front of Keycloak.
# Legacy KEYCLOAK_* remains as fallback; WEB_KEYCLOAK_* and ADMIN_KEYCLOAK_* take precedence.
# For learner (`apps/web`), prefer `WEB_KEYCLOAK_CLIENT_ID=nihongo-web` in `apps/web/.env.local` or here.
# Local Docker realm (`docker/keycloak/realm-export.json`): `nihongo-web` secret is `nihongo-web-dev-secret`.
# A mismatched `WEB_KEYCLOAK_CLIENT_SECRET` makes Keycloak return `unauthorized_client` (wrong client credentials).
# If only `KEYCLOAK_CLIENT_ID` is set in this file, it must match the learner client (`nihongo-web`) when the web
# app falls back to it — using `nihongo-admin` here breaks password-login on localhost:3000.
# The API `KeycloakTokenService` also falls back to WEB_KEYCLOAK_ISSUER_URL / WEB_KEYCLOAK_CLIENT_ID
# so learner JWTs match when the repo root `.env` mirrors Next `WEB_KEYCLOAK_*` only.
KEYCLOAK_ISSUER_URL=""
KEYCLOAK_CLIENT_ID=""
KEYCLOAK_CLIENT_SECRET=""
WEB_KEYCLOAK_ISSUER_URL=""
WEB_KEYCLOAK_CLIENT_ID=""
WEB_KEYCLOAK_CLIENT_SECRET=""
ADMIN_KEYCLOAK_ISSUER_URL=""
ADMIN_KEYCLOAK_CLIENT_ID=""
ADMIN_KEYCLOAK_CLIENT_SECRET=""
KEYCLOAK_EXPECTED_AUDIENCE=""
KEYCLOAK_PUBLIC_URL=""
# Browser apps: app-specific NEXT_PUBLIC_* takes precedence over legacy NEXT_PUBLIC_KEYCLOAK_*.
NEXT_PUBLIC_KEYCLOAK_ISSUER_URL=""
NEXT_PUBLIC_KEYCLOAK_URL=""
NEXT_PUBLIC_KEYCLOAK_REALM=""
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=""
NEXT_PUBLIC_WEB_KEYCLOAK_ISSUER_URL=""
NEXT_PUBLIC_WEB_KEYCLOAK_URL=""
NEXT_PUBLIC_WEB_KEYCLOAK_REALM=""
NEXT_PUBLIC_WEB_KEYCLOAK_CLIENT_ID=""
NEXT_PUBLIC_ADMIN_KEYCLOAK_ISSUER_URL=""
NEXT_PUBLIC_ADMIN_KEYCLOAK_URL=""
NEXT_PUBLIC_ADMIN_KEYCLOAK_REALM=""
NEXT_PUBLIC_ADMIN_KEYCLOAK_CLIENT_ID=""
# Set to 1/true if Node cannot reach Keycloak on `localhost` (IPv6 vs IPv4 loopback). Default: off — URLs match .env exactly.
KEYCLOAK_NODE_USE_IPV4_LOOPBACK=""
KEYCLOAK_JWKS_URL=""
# Comma-separated Keycloak realm or client role names allowed to open the admin app (before internal RBAC). Default: admin
KEYCLOAK_ADMIN_REALM_ROLES=""
# Optional comma-separated alias map from Keycloak roles to internal authz.admin_role codes. Default: admin:admin.super,superadmin:admin.super
KEYCLOAK_ADMIN_INTERNAL_ROLE_ALIASES=""

# OpenAI — image generation for BJT questions
OPENAI_API_KEY=
