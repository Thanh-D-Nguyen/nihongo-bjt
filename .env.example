NODE_ENV="development"

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:15432/nihongo_bjt?schema=content"
API_PORT="4000"
API_PUBLIC_URL="http://localhost:4000"
WEB_PUBLIC_URL="http://localhost:3000"
ADMIN_PUBLIC_URL="http://localhost:3001"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_LOCAL_ADMIN_ACTOR_ID="00000000-0000-4000-8000-000000000001"
# Local/test-only authenticated admin browser QA bypass.
# Requires NODE_ENV!="production", localhost/127.0.0.1 API requests, and a seeded authz.admin_actor matching NEXT_PUBLIC_LOCAL_ADMIN_ACTOR_ID.
# Set both API/Admin app env vars together, then restart both dev servers:
# ADMIN_TEST_BYPASS="1"
# NEXT_PUBLIC_ADMIN_TEST_BYPASS="1"

REDIS_URL="redis://localhost:6379"
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY="local_dev_meili_master_key"

MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="nihongo-bjt-media"
MINIO_USE_SSL="false"

# Google OAuth (Phase 12). Required for /api/auth/google/* routes to work.
OAUTH_STATE_SECRET=""
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:4000/api/auth/google/callback"

# Keycloak OIDC (sole auth when issuer is set). Prefer separate learner/admin clients.
# Issuer is the realm URL, e.g. http://localhost:8080/realms/nihongo-bjt
# Legacy KEYCLOAK_* remains as fallback; WEB_KEYCLOAK_* and ADMIN_KEYCLOAK_* take precedence.
KEYCLOAK_ISSUER_URL=""
KEYCLOAK_CLIENT_ID=""
KEYCLOAK_CLIENT_SECRET=""
WEB_KEYCLOAK_ISSUER_URL=""
WEB_KEYCLOAK_CLIENT_ID=""
WEB_KEYCLOAK_CLIENT_SECRET=""
ADMIN_KEYCLOAK_ISSUER_URL=""
ADMIN_KEYCLOAK_CLIENT_ID=""
ADMIN_KEYCLOAK_CLIENT_SECRET=""
KEYCLOAK_EXPECTED_AUDIENCE=""
KEYCLOAK_PUBLIC_URL=""
# Browser apps: app-specific NEXT_PUBLIC_* takes precedence over legacy NEXT_PUBLIC_KEYCLOAK_*.
NEXT_PUBLIC_KEYCLOAK_ISSUER_URL=""
NEXT_PUBLIC_KEYCLOAK_URL=""
NEXT_PUBLIC_KEYCLOAK_REALM=""
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=""
NEXT_PUBLIC_WEB_KEYCLOAK_ISSUER_URL=""
NEXT_PUBLIC_WEB_KEYCLOAK_URL=""
NEXT_PUBLIC_WEB_KEYCLOAK_REALM=""
NEXT_PUBLIC_WEB_KEYCLOAK_CLIENT_ID=""
NEXT_PUBLIC_ADMIN_KEYCLOAK_ISSUER_URL=""
NEXT_PUBLIC_ADMIN_KEYCLOAK_URL=""
NEXT_PUBLIC_ADMIN_KEYCLOAK_REALM=""
NEXT_PUBLIC_ADMIN_KEYCLOAK_CLIENT_ID=""
KEYCLOAK_JWKS_URL=""
# Comma-separated Keycloak realm or client role names allowed to open the admin app (before internal RBAC). Default: admin
KEYCLOAK_ADMIN_REALM_ROLES=""
